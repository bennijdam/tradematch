{
  "name": "tradematch-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "TradeMatch Frontend - Modern UK Trade Services Platform",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "python -m http.server 8080",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:codespaces": "bash scripts/dev-start-codespaces.sh",
    "build": "node scripts/automation/optimize-images.js && echo 'No other build step needed'",
    "build:production": "npm run build",
    "deploy:production": "npm --prefix apps/api run start",
    "start": "python -m http.server 8080",
    "seo:generate:main": "node scripts/automation/generate-pages.js main-pages",
    "seo:generate:locations": "node scripts/automation/generate-pages.js location-pages",
    "seo:generate:all": "node scripts/automation/generate-pages.js all-pages",
    "seo:sync:s3": "powershell -ExecutionPolicy Bypass -File scripts\\sync-seo-s3.ps1",
    "seo:sync:s3:sh": "bash scripts/sync-seo-s3.sh",
    "repo:cleanup:deps": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-node-modules.ps1",
    "lint": "pnpm run lint:html && pnpm run lint:css",
    "lint:html": "htmlhint \"apps/web/**/*.html\"",
    "lint:css": "stylelint \"apps/web/**/*.css\"",
    "test:smoke": "node scripts/smoke-test.js",
    "test:security": "node scripts/security-check.js",
    "test:ui-smoke": "node scripts/ui-smoke.js",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:sanity": "playwright test --grep @sanity",
    "test:e2e:journeys": "playwright test --grep @e2e",
    "test:e2e:journeys:headed": "playwright test --grep @e2e --headed",
    "test:e2e:journeys:slow": "playwright test --grep @e2e --headed --slow-mo=250"
  },
  "keywords": [
    "trades",
    "uk",
    "quotes",
    "tradespeople",
    "home-improvement"
  ],
  "author": "TradeMatch Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "htmlhint": "^1.7.1",
    "playwright": "^1.58.2",
    "serve": "^14.2.6",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.38.0",
    "@vercel/analytics": "^1.6.1",
    "dotenv": "^17.2.3",
    "pg": "^8.17.2",
    "sharp": "^0.34.5",
    "undici": "^7.24.3"
  }
}
