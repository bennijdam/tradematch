{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "public": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "x-tradematch-debug", "value": "v2-active" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/apps/api/$1" },
    { "source": "/images/(.*)", "destination": "/images/$1" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/dashboard", "destination": "/vendor-dashboard.html" },
    { "source": "/home", "destination": "/customer-dashboard.html" }
  ]
}
