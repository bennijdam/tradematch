{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://api.tradematch.uk/api/$1" },
    { "source": "/images/(.*)", "destination": "/apps/web/images/$1" },
    { "source": "/shared/(.*)", "destination": "/apps/web/shared/$1" },
    { "source": "/js/(.*)", "destination": "/apps/web/js/$1" },
    { "source": "/frontend/(.*)", "destination": "/apps/web/shared/$1" },
    { "source": "/((?!api/).*)", "destination": "/apps/web/$1" }
  ]
}
