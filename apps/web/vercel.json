      "destination": "/messages.html"
    },
    {
      "source": "/user-dashboard/my-jobs",
      "destination": "/my-jobs.html"
    },
    {
      "source": "/user-dashboard/notifications",
      "destination": "/notifications.html"
    },
    {
      "source": "/user-dashboard/post-job",
      "destination": "/post-job.html"
    },
    {
      "source": "/user-dashboard/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/user-dashboard/quotes",
      "destination": "/quotes.html"
    },
    {
      "source": "/user-dashboard/reviews",
      "destination": "/reviews.html"
    },
    {
      "source": "/user-dashboard/saved-trades",
      "destination": "/saved-trades.html"
    },
    {
      "source": "/user-dashboard/settings",
      "destination": "/settings.html"
    },
    {
      "source": "/user-dashboard/your-quotes",
      "destination": "/your-quotes.html"
    },
    {
      "source": "/vendor-dashboard/vendor-active-quotes",
      "destination": "/vendor-active-quotes.html"
    },
    {
      "source": "/vendor-dashboard/vendor-analytics",
      "destination": "/vendor-analytics.html"
    },
    {
      "source": "/vendor-dashboard/vendor-archived-jobs",
      "destination": "/vendor-archived-jobs.html"
    },
    {
      "source": "/vendor-dashboard/vendor-badges",
      "destination": "/vendor-badges.html"
    },
    {
      "source": "/vendor-dashboard/vendor-billing",
      "destination": "/vendor-billing.html"
    },
    {
      "source": "/vendor-dashboard/vendor-coverage",
      "destination": "/vendor-coverage.html"
    },
    {
      "source": "/vendor-dashboard/vendor-dashboard-enhanced",
      "destination": "/vendor-dashboard-enhanced.html"
    },
    {
      "source": "/vendor-dashboard/vendor-dashboard-with-modals",
      "destination": "/vendor-dashboard.html"
    },
    {
