    },
    {
      "source": "/trade-signup",
      "destination": "/vendor-register.html"
    },
    {
      "source": "/user-dashboard",
      "destination": "/user-dashboard-index.html"
    },
    {
      "source": "/vendor-dashboard",
      "destination": "/vendor-dashboard.html"
    },
    {
      "source": "/super-admin",
      "destination": "/super-admin-dashboard-index.html"
    },
    {
      "source": "/user-dashboard/billing-addons",
      "destination": "/billing-addons.html"
