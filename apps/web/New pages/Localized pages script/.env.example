# Optional: Pexels API key for stock image ingestion
PEXELS_API_KEY=

# Optional: Unsplash access key for stock image ingestion fallback
UNSPLASH_ACCESS_KEY=

# Optional: OpenAI key for external batch content generation pipeline
OPENAI_API_KEY=

# Optional: AWS settings for uploading generated output/assets to S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# Optional: Cloudflare/R2 public asset origin used in rendered HTML
# Example: https://assets.tradematch.uk
ASSET_BASE_URL=
